{
  "apiKeyHelper": "airnity auth print-access-token",
  "env": {
    "ANTHROPIC_BASE_URL": "https://bifrost.airnity.io/anthropic",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "vertex/claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "vertex/claude-opus-4-6",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "vertex/claude-haiku-4-5@20251001",
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "mcp__bifrost__listToolFiles",
      "mcp__bifrost__readToolFile",
      "mcp__bifrost__executeToolCode",
      "mcp__bifrost__getToolDocs",
      "mcp__chrome-devtools__new_page",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__click",
      "mcp__chrome-devtools__press_key",
      "mcp__chrome-devtools__resize_page",
      "mcp__chrome-devtools__get_console_message",
      "mcp__chrome-devtools__list_network_requests",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__list_console_messages"
    ],
    "deny": []
  },
  "model": "opusplan",
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Funk.aiff",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Submarine.aiff",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "autoUpdatesChannel": "latest",
  "skipAutoPermissionPrompt": true
}
